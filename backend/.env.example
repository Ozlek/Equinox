# Django Secret Key — generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-secure-random-key

# Set to True for development, False for production
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of allowed CORS origins (the React frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated list of CSRF trusted origins
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to True in production when using HTTPS
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Database URL (defaults to SQLite if not set)
# For PostgreSQL: postgres://user:password@host:port/dbname
DATABASE_URL=